Bootstrap: docker
From: ubuntu:22.04

%environment
    export LANG=C.UTF-8
    export LC_ALL=C.UTF-8
    export PATH=/usr/local/bin:/usr/bin:$PATH

%post
    # Modo no interactivo para evitar preguntas durante la instalación
    export DEBIAN_FRONTEND=noninteractive
    
    # Actualizar lista de paquetes
    apt update
    apt upgrade -y
    
    # Instalar Java (necesario para FastQC)
    apt install -y default-jre
    
    # Instalar FastQC
    apt install -y fastqc
    
    # Instalar Python y pip para MultiQC
    apt install -y python3 python3-pip
    
    # Instalar MultiQC mediante pip
    pip3 install multiqc
    
    # Limpiar para reducir el tamaño de la imagen
    apt clean
    rm -rf /var/lib/apt/lists/*

%runscript
    echo "Contenedor para Inspección de Calidad de Secuencias"
    echo "Herramientas disponibles: fastqc, multiqc"
    exec "$@"

%labels
    Author Jorge Alberto Castro Rodríguez
    Version 1.0
    Description Contenedor para verificación de integridad y análisis de calidad de secuencias con FastQC y MultiQC